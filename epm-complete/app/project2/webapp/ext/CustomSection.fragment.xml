<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <VBox id="vbStock" class="sapUiSmallMargin">

        <Title
            id="titleStock"
            text="Stock Visualization"
            level="H3"/>

        <ProgressIndicator
            id="piStock"
            percentValue="{= ${stock} / ${maxStock} * 100}"
            displayValue="{= ${stock} + ' / ' + ${maxStock}}"
            state="{= ${stock} > 20 ? 'Success' : ${stock} > 0 ? 'Warning' : 'Error'}"/>

        <Text
            id="txtReorder"
            text="Reorder needed: {= ${stock} &lt; ${minStock} ? 'Yes' : 'No'}"/>

    </VBox>

</core:FragmentDefinition>