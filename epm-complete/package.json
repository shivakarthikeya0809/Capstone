{
  "name": "epm-complete",
  "version": "1.0.0",
  "private": true,
  "dependencies": {
    "@cap-js/hana": "^2",
    "@sap/cds": "^9",
    "@sap/xssec": "^4"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2.4",
    "@sap/cds-dk": "^9.9.2",
    "cds-plugin-ui5": "^0.17.0"
  },
  "scripts": {
    "start": "cds-serve",
    "watch-purchase": "cds watch --open purchase/index.html?sap-ui-xx-viewCache=false --livereload false"
  },
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/project4"
  ],
  "cds": {
    "requires": {
      "db": {
        "kind": "sqlite",
        "credentials": {
          "url": "db/epm.db"
        },
        "[production]": {
          "kind": "hana"
        }
      },
      "auth": {
        "kind": "xsuaa",
        "[development]": {
          "kind": "mocked",
          "user": "alice",
          "users": {
            "alice": {
              "password": "alice",
              "roles": [
                "PurchaseManager"
              ]
            },
            "bob": {
              "password": "bob",
              "roles": [
                "Administrator"
              ]
            },
            "carol": {
              "password": "carol",
              "roles": [
                "Viewer"
              ]
            },
            "dave": {
              "password": "dave",
              "roles": [
                "Administrator"
              ]
            }
          }
        }
      }
    }
  }
}
