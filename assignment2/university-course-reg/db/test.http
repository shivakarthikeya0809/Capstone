### Get courses filtered by department and semester
GET http://port4004-workspaces-ws-76zvt.ap21.trial.applicationstudio.cloud.sap/odata/v4/university/Courses?$filter=department eq 'CSE' and semester eq 5

### Get students with CGPA above 8.0
GET http://port4004-workspaces-ws-76zvt.ap21.trial.applicationstudio.cloud.sap/odata/v4/university/Students?$filter=cgpa gt 8.0

### Create a new enrollment
POST http://port4004-workspaces-ws-76zvt.ap21.trial.applicationstudio.cloud.sap/odata/v4/university/Enrollments
Content-Type: application/json

{
  "ID": "E001",
  "student_ID": "S001",
  "course_ID": "C001",
  "grade": null
}

### Get all enrollments for a specific student
GET http://port4004-workspaces-ws-76zvt.ap21.trial.applicationstudio.cloud.sap/odata/v4/university/Enrollments?$filter=student_ID eq 'S001'

### Get courses with seats available
GET http://port4004-workspaces-ws-76zvt.ap21.trial.applicationstudio.cloud.sap/odata/v4/university/Courses?$filter=currentEnrolled lt maxStudents

### Update enrollment grade
PATCH http://port4004-workspaces-ws-76zvt.ap21.trial.applicationstudio.cloud.sap/odata/v4/university/Enrollments('E001')
Content-Type: application/json

{
  "grade": "A"
}