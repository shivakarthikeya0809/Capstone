Content-Type: application/json

{
  "orderNumber": "SO-005",
  "customer_ID": "c1111111-1111-1111-1111-111111111111",
  "orderDate": "2026-06-05",
  "totalAmount": 3300,
  "taxAmount": 594,
  "netAmount": 3894,
  "currency_code": "INR",
  "status": "Created",
  "items": [
    {
      "product_ID": "p3333333-3333-3333-3333-333333333333",
      "quantity": 1,
      "unitPrice": 800,
      "netAmount": 800
    },
    {
      "product_ID": "p4444444-4444-4444-4444-444444444444",
      "quantity": 1,
      "unitPrice": 2500,
